---
layout: layouts/base
year: 2025
eleventyComputed:
  title: "Artister {{ year }}"
  permalink: "{% if year == editions.current %}/scen/index.html{% else %}/{{ year }}/scen/index.html{% endif %}"
---

<h1>Artister {{ year }}</h1>

{#- Filter to only non-headline acts with an artist page -#}
{%- set others = [] -%}
{%- for act in lineup -%}
  {%- if act.page == "artist" and act.placement != "headline" -%}
    {%- set others = (others.push(act), others) -%}
  {%- endif -%}
{%- endfor -%}

{% include "components/headline-acts/headline-acts.njk" %}

{% if others.length %}
<section>
  <h2>Övriga artister</h2>
  <ul>
    {% for act in others | sort(false, false, 'name') %}
      <li>
        {% if act.image or act.longdescription %}
          <a href="{% if year == editions.current %}/scen/{{ act.name | slugify }}/{% else %}/{{ year }}/scen/{{ act.name | slugify }}/{% endif %}">{{ act.name }}</a>
        {% else %}
          <span>{{ act.name }}</span>
        {% endif %}
        <span>{{ act.day | capitalize }} · {{ act.starttime }}–{{ act.endtime }} · {{ act.stage }}</span>
      </li>
    {% endfor %}
  </ul>
</section>
{% endif %}