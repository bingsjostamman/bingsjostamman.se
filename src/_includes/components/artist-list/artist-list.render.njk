{#- Render wrapper for prebuild-stories.js
    Cannot use the real template because it imports thumbnailImage which depends
    on Cloudinary. Reproduces the same HTML structure with placeholder images. -#}
{% from "components/artist-meta/artist-meta.njk" import artistMetaItem %}

{%- set others = [] -%}
{%- set headlineKeys = [] -%}
{%- set seenKeys = [] -%}

{%- for act in lineup -%}
  {%- if act.page == "artist" and (act.placement | trim | lower) == "headline" -%}
    {%- set headlineKey = act.ref or act.name -%}
    {%- if headlineKey and headlineKeys.indexOf(headlineKey) == -1 -%}
      {%- set headlineKeys = (headlineKeys.push(headlineKey), headlineKeys) -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- for act in lineup -%}
  {%- if act.page == "artist" -%}
    {%- set groupKey = act.ref or act.name -%}
    {%- if groupKey and headlineKeys.indexOf(groupKey) == -1 and seenKeys.indexOf(groupKey) == -1 -%}
      {%- set seenKeys = (seenKeys.push(groupKey), seenKeys) -%}
      {%- set others = (others.push(act), others) -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- if others.length -%}
<section class="c-artist-list">
  <h2 class="c-artist-list__heading">Övriga akter</h2>
  <ul class="c-artist-list__list">
    {%- for act in others | sort(false, false, 'name') %}
    <li class="c-artist-list__item">
      {%- if act.image %}
      <div class="c-artist-list__image">
        <img src="https://placehold.co/300x300?text={{ act.name | urlencode }}" alt="{{ act.name }}" loading="lazy" width="300" height="300">
      </div>
      {%- endif %}
      <div class="c-artist-list__body">
        {%- if act.longdescription %}
        <a class="c-artist-list__name" href="/scen/{{ act.name | lower | replace(" ", "-") }}/">{{ act.name }}</a>
        {%- else %}
        <span class="c-artist-list__name">{{ act.name }}</span>
        {%- endif %}
        {%- set slots = [] -%}
        {%- set groupKey = act.ref or act.name -%}
        {%- for slot in lineup -%}
          {%- set slotKey = slot.ref or slot.name -%}
          {%- if slot.page == "artist" and slotKey == groupKey and (slot.placement | trim | lower) != "headline" -%}
            {%- set slots = (slots.push(slot), slots) -%}
          {%- endif -%}
        {%- endfor -%}
        {%- for slot in slots %}
        {{ artistMetaItem(slot.stage, slot.day, slot.starttime, slot.endtime, {
          tag: "div",
          rootClass: "c-artist-list__meta artist-meta-item",
          infoClass: "c-artist-list__meta-info artist-meta-info",
          locationClass: "artist-meta-location"
        }) }}
        {%- endfor %}
      </div>
    </li>
    {%- endfor %}
  </ul>
</section>
{%- endif -%}
