{#-
  Component: Artist List
  Renders a list of non-headline artists with optional thumbnail,
  link to artist page, and all stage slots (grouped via ref).

  Expects in context:
    - lineup: array of act objects (full lineup)
    - year: string
    - editions: object with .current
-#}

{% from "components/image/image-thumbnail.njk" import thumbnailImage %}
{% from "components/icon/icon.njk" import icon %}

{%- set others = [] -%}
{%- for act in lineup -%}
  {%- if act.page == "artist" and act.placement != "headline" -%}
    {%- set others = (others.push(act), others) -%}
  {%- endif -%}
{%- endfor -%}

{%- if others.length -%}
<section class="c-artist-list">
  <h2 class="c-artist-list__heading">Övriga artister</h2>
  <ul class="c-artist-list__list">
    {%- for act in others | sort(false, false, 'name') %}
    <li class="c-artist-list__item">
      {%- if act.image %}
      <div class="c-artist-list__image">
        {{ thumbnailImage(act.image | replace(".jpg", "") | replace(".png", ""), act.name) }}
      </div>
      {%- endif %}
      <div class="c-artist-list__body">
        {%- if act.longdescription %}
        <a class="c-artist-list__name" href="{% if year == editions.current %}/scen/{{ act.name | slugify }}/{% else %}/{{ year }}/scen/{{ act.name | slugify }}/{% endif %}">{{ act.name }}</a>
        {%- else %}
        <span class="c-artist-list__name">{{ act.name }}</span>
        {%- endif %}
        {%- set slots = [] -%}
        {%- if act.ref -%}
          {%- for slot in lineup -%}
            {%- if slot.ref == act.ref -%}
              {%- set slots = (slots.push(slot), slots) -%}
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- set slots = (slots.push(act), slots) -%}
        {%- endif -%}
        {%- for slot in slots %}
        <span class="c-artist-list__meta">{{ icon("schedule") }}{{ slot.day | capitalize }} · {{ slot.starttime }}–{{ slot.endtime }} · {{ icon("location") }}{{ slot.stage }}</span>
        {%- endfor %}
      </div>
    </li>
    {%- endfor %}
  </ul>
</section>
{%- endif -%}
