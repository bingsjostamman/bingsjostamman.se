---
layout: layouts/base
title: Accessibility Report
permalink: /test/accessibility/
eleventyExcludeFromCollections: true
---

{% set report = axecore or accessibility %}

<div class="o-compound a11y-report">
  <header class="a11y-report__header">
    <h1>Tillgänglighetsrapport</h1>
    <p>Automatiserad granskning med axe-core av byggd webbplats.</p>
  </header>

  {% if report and report.summary %}
    {% if report.summary.skipped %}
      <section class="a11y-warning" role="status" aria-live="polite">
        <h2>Tillgänglighetskontrollen kunde inte köras</h2>
        <p>
          Rapporten innehåller ingen skanning i denna körning.
          Orsak: {{ report.summary.reason or "okänd" }}
        </p>
      </section>
    {% endif %}

    <section class="a11y-summary" aria-label="Rapportsammanfattning">
      <article class="a11y-summary__card">
        <p class="a11y-summary__label">Sidor testade</p>
        <p class="a11y-summary__value">{{ report.summary.totalPages }}</p>
      </article>
      <article class="a11y-summary__card">
        <p class="a11y-summary__label">Totalt antal avvikelser</p>
        <p class="a11y-summary__value">{{ report.summary.totalViolations }}</p>
      </article>
      <article class="a11y-summary__card">
        <p class="a11y-summary__label">Sidor med avvikelser</p>
        <p class="a11y-summary__value">{{ report.summary.pagesWithIssues }}</p>
      </article>
    </section>

    {% if report.summary.timestamp %}
      <p class="a11y-report__timestamp">
        Senast uppdaterad: {{ report.summary.timestamp | date("yyyy-MM-dd HH:mm") }}
      </p>
    {% endif %}

    <section class="a11y-report__details" lang="en" aria-label="Accessibility findings">
      {% for page in report.pages %}
        {% if page.violations and page.violations.length %}
          <article class="a11y-page">
            <h2>{{ page.path }}</h2>
            <p class="a11y-page__meta">
              <strong>{{ page.violations.length }}</strong>
              issue{% if page.violations.length > 1 %}s{% endif %} found
            </p>

            <ul class="a11y-issues">
              {% for issue in page.violations %}
                <li class="a11y-issue impact-{{ issue.impact or 'unknown' }}">
                  <h3>{{ issue.help }}</h3>

                  {% if issue.description %}
                    <p>{{ issue.description }}</p>
                  {% endif %}

                  {% if issue.helpUrl %}
                    <p>
                      <a href="{{ issue.helpUrl }}" target="_blank" rel="noopener noreferrer">
                        Learn more about this rule
                      </a>
                    </p>
                  {% endif %}

                  {% if issue.nodes and issue.nodes.length %}
                    <details>
                      <summary>Affected elements ({{ issue.nodes.length }})</summary>
                      <ul class="a11y-nodes">
                        {% for node in issue.nodes %}
                          <li>
                            <code>{{ node.target | join(', ') }}</code>
                            {% if node.failureSummary %}
                              <p>{{ node.failureSummary }}</p>
                            {% endif %}
                          </li>
                        {% endfor %}
                      </ul>
                    </details>
                  {% endif %}
                </li>
              {% endfor %}
            </ul>
          </article>
        {% endif %}
      {% endfor %}
    </section>
  {% else %}
    <p>Ingen tillgänglighetsrapport hittades eller datan har fel format.</p>
  {% endif %}
</div>

<style>
  .a11y-report {
    margin-block: 1.5rem 3rem;
  }

  .a11y-report__header {
    margin-bottom: 1.5rem;
  }

  .a11y-report__header h1 {
    margin-bottom: 0.5rem;
  }

  .a11y-summary {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.9rem;
    margin-bottom: 1rem;
  }

  .a11y-warning {
    border: 1px solid #f59e0b;
    background: #fffbeb;
    border-radius: 0.7rem;
    padding: 1rem;
    margin-bottom: 1rem;
  }

  .a11y-warning h2 {
    margin: 0 0 0.4rem;
    font-size: 1.1rem;
  }

  .a11y-warning p {
    margin: 0;
  }

  .a11y-summary__card {
    border: 1px solid #d5dbe2;
    background: #f6f8fa;
    border-radius: 0.7rem;
    padding: 0.9rem;
  }

  .a11y-summary__label {
    margin: 0;
    font-size: 0.9rem;
    color: #334155;
  }

  .a11y-summary__value {
    margin: 0.35rem 0 0;
    font-size: 1.6rem;
    font-weight: 700;
  }

  .a11y-report__timestamp {
    color: #475569;
    margin-bottom: 1.5rem;
  }

  .a11y-page {
    border: 1px solid #d5dbe2;
    border-radius: 0.7rem;
    padding: 1rem;
    margin-bottom: 1rem;
    background: #fff;
  }

  .a11y-page h2 {
    margin: 0 0 0.35rem;
    font-size: 1.15rem;
    overflow-wrap: anywhere;
  }

  .a11y-page__meta {
    margin-top: 0;
    color: #334155;
  }

  .a11y-issues {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .a11y-issue {
    border-left: 4px solid #cbd5e1;
    background: #f8fafc;
    border-radius: 0 0.5rem 0.5rem 0;
    padding: 0.75rem 0.9rem;
    margin-bottom: 0.8rem;
  }

  .a11y-issue h3 {
    margin-top: 0;
    font-size: 1rem;
  }

  .impact-minor { border-left-color: #65a30d; }
  .impact-moderate { border-left-color: #d97706; }
  .impact-serious { border-left-color: #dc2626; }
  .impact-critical { border-left-color: #991b1b; }

  .a11y-nodes {
    margin-top: 0.6rem;
    padding-left: 1.1rem;
  }

  .a11y-issue details summary {
    cursor: pointer;
    font-weight: 600;
  }

  code {
    display: inline-block;
    max-width: 100%;
    overflow-x: auto;
    background: #e2e8f0;
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
  }
</style>