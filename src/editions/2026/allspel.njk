---
layout: layouts/base
description: "Allspelslåtar for Bingsjöstämman {{ year }}."
eleventyComputed:
  title: "Allspel {{ year }}"
  permalink: "{% if year == editions.current %}/allspel/index.html{% else %}/{{ year }}/allspel/index.html{% endif %}"
---
{% from "components/allspel-tunes/allspel-tunes.njk" import allspelTunes %}
{% from "components/image/image.njk" import cloudinaryPicture %}
{% set regularTunes = tunes | rejectattr("barnens") | list %}
{% set barnensTunes = tunes | selectattr("barnens") | list %}

<div class="o-split">
  <div class="o-split__content prose">
    <h1>Allspelslåtar {{ year }}</h1>

    <div class="page-intro">
      {{ copy.intro | markdown | safe }}
    </div>
  </div>
  <div class="o-split__image o-split__content">
    {{ cloudinaryPicture("v1748295028/allspel_2024_zchx2s", "Allspel på stora scenen") }}
  </div>
</div>



{{ allspelTunes(regularTunes) }}

