---
layout: layouts/base
year: 2026
pagination:
  data: lineup
  size: 1
  alias: artist
  addAllPagesToCollections: true
eleventyComputed:
  title: "{{ artist.name or 'Unknown' }}"
  permalink: "{% if year == editions.current %}/scen/{{ (artist.name or 'unknown') | slugify }}/{% else %}/{{ year }}/scen/{{ (artist.name or 'unknown') | slugify }}/{% endif %}"
---

{% from "components/image/image-hero.njk" import heroImage %}
{% from "components/icon/icon.njk" import icon %}


<article class="artist">
  <div class="artist-intro">
    <h1 class="artist-headline">
      {%- if artist.eyebrow %}
      <span class="artist__eyebrow">{{ icon("music") }}{{ artist.eyebrow }}</span>
      {%- endif %}
      {{ artist.name }}
    </h1>

    {% if artist.image %}
      <div class="artist-image">
        {{ heroImage(artist.image | replace(".jpg", "") | replace(".png", ""), artist.name) }}
      </div>
    {% endif %}
  </div>

    {# Gather all slots for this artist by ref - filter manually since selectattr doesn't support variables #}
    {% set allSlots = [] %}
    {% for slot in fullLineup %}
      {% if slot.page == "artist" and slot.ref == artist.ref %}
        {% set allSlots = allSlots.concat([slot]) %}
      {% endif %}
    {% endfor %}

  <div class="artist-split o-split o-split--uneven">
  {% if artist.longdescription %}
    <div class="artist-longdescription">
      {{ artist.longdescription }}
    </div>
  {% endif %}

      {% if allSlots.length > 1 %}
        {% set dayOrder = {"tisdag": 1, "onsdag": 2} %}
        {% set decoratedSlots = [] %}
        {% for slot in allSlots %}
          {% set rank = dayOrder[slot.day] or 99 %}
          {% set sortKey = (rank * 10000) + (slot.startMinutes or 0) %}
          {% set decoratedSlots = (decoratedSlots.push({"sortKey": sortKey, "slot": slot}), decoratedSlots) %}
        {% endfor %}
        {% set sortedSlots = decoratedSlots | sort(false, false, "sortKey") %}
      <ul class="artist-meta u-list-unstyled o-tile t-intent-emphasis">
          {% for row in sortedSlots %}
            {% set slot = row.slot %}
          <li class="artist-meta-item">
            <div class="artist-meta-info artist-meta-location">{{ icon("location", "artist-meta-icon") }}{{ slot.stage }}</div>
            <time class="artist-meta-info">{{ icon("schedule", "artist-meta-icon") }}{{ slot.day | capitalize }} {{ slot.starttime }}–{{ slot.endtime }}</time>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <div class="artist-meta o-tile t-intent-emphasis">
          <div class="artist-meta-item">
            <div class="artist-meta-info artist-meta-location">{{ icon("location", "artist-meta-icon") }}{{ artist.stage }}</div>
            <time class="artist-meta-info">{{ icon("schedule", "artist-meta-icon") }}{{ artist.day | capitalize }} {{ artist.starttime }}–{{ artist.endtime }}</time>
          </div>
      </div>
    {% endif %}


  {% if artist.link %}
    <div>
      <a class="artist-link" href="{{ artist.link }}" target="_blank" rel="external noopener noreferrer">Besök webbplats <span class="u-visually-hidden">(Öppnas i nytt fönster)</span>{{ icon("open-in-new")}}</a>
    </div>
  {% endif %}

  {%- if artist.ref %}
    {% set relatedSlots = [] %}
    {% for slot in fullLineup %}
      {% if slot.ref == artist.ref and slot.name != artist.name %}
        {% set relatedSlots = (relatedSlots.push(slot), relatedSlots) %}
      {% endif %}
    {% endfor %}

    {% if relatedSlots.length %}
    <section class="artist-related">
      <h2>Fler spelningar</h2>
      <ul>
        {% for slot in relatedSlots %}
          <li>
            <strong>{{ slot.name }}</strong><br>
            {{ slot.day | capitalize }}{% if dates[slot.day] %}, {{ dates[slot.day] }}{% endif %}
            · {{ slot.starttime }}–{{ slot.endtime }}
            · {{ slot.stage }}
            {% if slot.description %}<p>{{ slot.description }}</p>{% endif %}
          </li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}
  {%- endif %}

  </div> <!-- end: compound -->
</article>

{% if year != editions.current %}
<div class="archive-banner">
  This is an archive from {{ year }}.
  <a href="/">View current festival →</a>
</div>
<meta name="robots" content="noindex">
{% endif %}