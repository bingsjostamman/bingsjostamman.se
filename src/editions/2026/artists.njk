---
layout: layouts/base
year: 2026
pagination:
  data: lineup
  size: 1
  alias: artist
  addAllPagesToCollections: true
eleventyComputed:
  title: "{{ artist.name }}"
  description: "{{ artist.description or ('Artist pa Bingsjostamman ' ~ year) }}"
  socialImage: "{{ artist.image and ('https://res.cloudinary.com/dbblxggj5/image/upload/c_fill,w_1200,h_630,q_auto,f_auto/' ~ artist.image) or site.defaultImage }}"
  permalink: "{% if year == editions.current %}/scen/{{ artist.name | slugify }}/{% else %}/{{ year }}/scen/{{ artist.name | slugify }}/{% endif %}"
eleventyExcludeFromCollections: true
---

{% from "components/image/image-hero.njk" import heroImage %}

<article>
  
</article>

{% if year != editions.current %}
<div class="archive-banner">
  This is an archive from {{ year }}.
  <a href="/">View current festival →</a>
</div>
<meta name="robots" content="noindex">
{% endif %}