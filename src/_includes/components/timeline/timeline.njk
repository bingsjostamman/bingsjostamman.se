{#
  Timeline schedule component
  Renders a CSS Grid visual timeline with stages as columns and time as rows.

  Usage:
    {% from "components/timeline/timeline.njk" import timeline %}
    {{ timeline(lineup, { day: "onsdag" }) }}
    {{ timeline(lineup, { day: "onsdag", stages: ["Logen", "Tunet", "Låttältet"] }) }}
    {{ timeline(lineup, { type: "dansa" }) }}

  Parameters:
    - lineup:  array – the full lineup data (needs startMinutes / endMinutes)
    - options: object with optional keys:
        day      – "tisdag" | "onsdag"  (required in practice)
        stages   – array of stage names to include (default: auto-detect from filtered acts)
    type     – filter by act type, e.g. "dansa", "lyssna"
    types    – array of act types to include, e.g. ["spela", "kurs"]
        startHour – first visible hour (default: auto from earliest act, rounded down)
        endHour   – last visible hour  (default: auto from latest act, rounded up)
        increment – grid resolution in minutes (default: 10)
#}

{% from "components/icon/icon.njk" import icon %}

{%- macro timeline(lineup, options) -%}
{# ── 1. Filter acts ────────────────────────────────────── #}
{%- set filtered = [] -%}
{%- for act in lineup -%}
  {%- set dominated = true -%}
  {%- if options.day and act.day != options.day -%}{%- set dominated = false -%}{%- endif -%}
  {%- if options.type -%}
    {%- if options.type.join -%}
      {%- set typeMatch = false -%}
      {%- for typeName in options.type -%}
        {%- if typeName == act.type -%}{%- set typeMatch = true -%}{%- endif -%}
      {%- endfor -%}
      {%- if not typeMatch -%}{%- set dominated = false -%}{%- endif -%}
    {%- else -%}
      {%- if act.type != options.type -%}{%- set dominated = false -%}{%- endif -%}
    {%- endif -%}
  {%- endif -%}
  {%- if options.types and options.types.length -%}
    {%- set typeMatch = false -%}
    {%- for typeName in options.types -%}
      {%- if typeName == act.type -%}{%- set typeMatch = true -%}{%- endif -%}
    {%- endfor -%}
    {%- if not typeMatch -%}{%- set dominated = false -%}{%- endif -%}
  {%- endif -%}
  {%- if options.stages and options.stages.length -%}
    {%- set stageMatch = false -%}
    {%- for s in options.stages -%}
      {%- if s == act.stage -%}{%- set stageMatch = true -%}{%- endif -%}
    {%- endfor -%}
    {%- if not stageMatch -%}{%- set dominated = false -%}{%- endif -%}
  {%- endif -%}
  {%- if dominated -%}
    {%- set filtered = (filtered.push(act), filtered) -%}
  {%- endif -%}
{%- endfor -%}

{%- if filtered.length -%}
{# ── 2. Derive stage list (preserve order from options, or sort by first appearance) ── #}
{%- if options.stages and options.stages.length -%}
  {%- set stageNames = options.stages -%}
{%- else -%}
  {%- set stageNames = [] -%}
  {%- for act in filtered -%}
    {%- set already = false -%}
    {%- for s in stageNames -%}
      {%- if s == act.stage -%}{%- set already = true -%}{%- endif -%}
    {%- endfor -%}
    {%- if not already -%}
      {%- set stageNames = (stageNames.push(act.stage), stageNames) -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{# ── 3. Compute time bounds ────────────────────────────── #}
{%- set inc = options.increment if options.increment else 10 -%}

{%- set minMin = 9999 -%}
{%- set maxMin = 0 -%}
{%- for act in filtered -%}
  {%- if act.startMinutes < minMin -%}{%- set minMin = act.startMinutes -%}{%- endif -%}
  {%- if act.endMinutes > maxMin -%}{%- set maxMin = act.endMinutes -%}{%- endif -%}
{%- endfor -%}

{# Round down to nearest hour for start, up for end #}
{%- if options.startHour -%}
  {%- set gridStart = options.startHour * 60 -%}
{%- else -%}
  {%- set gridStart = (minMin / 60) | round(0, "floor") * 60 -%}
{%- endif -%}

{%- if options.endHour -%}
  {%- set gridEnd = options.endHour * 60 -%}
{%- else -%}
  {%- set gridEnd = (maxMin / 60) | round(0, "ceil") * 60 -%}
{%- endif -%}

{%- set totalSlots = ((gridEnd - gridStart) / inc) | round(0, "ceil") -%}

{# ── 4. Render ─────────────────────────────────────────── #}
<div class="c-timeline o-block o-block--margin-medium" aria-hidden="true" style="--timeline-cols: {{ stageNames.length }}; --timeline-rows: {{ totalSlots }};">
  {# Column headers #}
  <div class="c-timeline__header" style="grid-row: 1;">
    <div class="c-timeline__corner"></div>
    {%- for stage in stageNames %}
    <div class="c-timeline__stage-label c-timeline__stage-label--col-{{ "a" if loop.index % 2 == 1 else "b" }}" style="grid-column: {{ loop.index + 1 }};">{{ icon("location") }}{{ stage }}</div>
    {%- endfor %}
  </div>

  {# Time labels along left edge #}
  {%- for i in range(0, totalSlots) -%}
    {%- set mins = gridStart + (i * inc) -%}
    {%- if mins % 60 == 0 -%}
    {%- set displayHour = ((mins / 60) | round(0, "floor")) % 24 -%}
    {%- set displayHourText = "0" ~ displayHour if displayHour < 10 else displayHour -%}
    <div class="c-timeline__time" style="grid-row: {{ i + 2 }}; grid-column: 1;">
      {{ displayHourText }}:00
    </div>
    {%- endif -%}
  {%- endfor -%}

  {# Hour grid lines #}
  {%- for i in range(0, totalSlots) -%}
    {%- set mins = gridStart + (i * inc) -%}
    {%- if mins % 60 == 0 -%}
    <div class="c-timeline__hour-line" style="grid-row: {{ i + 2 }}; grid-column: 1 / -1;" aria-hidden="true"></div>
    {%- endif -%}
  {%- endfor -%}

  {# Act blocks #}
  {%- for stage in stageNames -%}
    {%- set colIdx = loop.index -%}
    {%- set colStripe = "a" if colIdx % 2 == 1 else "b" -%}
    {%- set slotIdx = 0 -%}
    {%- for act in filtered -%}
      {%- if act.stage == stage -%}
        {%- set slotIdx = slotIdx + 1 -%}
        {%- set slotStripe = "a" if slotIdx % 2 == 1 else "b" -%}

        {# Snap both boundaries to nearest grid step for stable visual timing. #}
        {%- set startSlot = (((act.startMinutes - gridStart) / inc) + 0.5) | round(0, "floor") -%}
        {%- set endSlot = (((act.endMinutes - gridStart) / inc) + 0.5) | round(0, "floor") -%}
        {%- if endSlot <= startSlot -%}
          {%- set endSlot = startSlot + 1 -%}
        {%- endif -%}

        {# Compute grid rows (+2 because row 1 is the header). #}
        {%- set rowStart = startSlot + 2 -%}
        {%- set rowEnd = endSlot + 2 -%}

        <div class="c-timeline__act c-timeline__act--col-{{ colStripe }} c-timeline__act--slot-{{ slotStripe }}"
             style="grid-row: {{ rowStart }} / {{ rowEnd }}; grid-column: {{ colIdx + 1 }};">
          <span class="c-timeline__act-time">{{ icon("schedule") }}{{ act.starttime }}–{{ act.endtime }}</span>
          <span class="c-timeline__act-name">{{ act.name }}</span>
        </div>
      {%- endif -%}
    {%- endfor -%}
  {%- endfor -%}
</div>
{%- endif -%}
{%- endmacro -%}
