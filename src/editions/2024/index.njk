---
layout: layouts/base
year: 2024
eleventyComputed:
  title: "{{ year }}"
  permalink: "{% if year == editions.current %}/index.html{% else %}/{{ year }}/index.html{% endif %}"
  isArchive: "{{ year != editions.current }}"
---

<h1>Bingsjöstämmans {{ year }}</h1>
<p>Välkommen till festivalen! {{editions.current }} {{ isArchive }}</p>

{% include "components/headline-acts/headline-acts.njk" %}

<ul>
  <li>
    <a href="{% if year == editions.current %}/scen/{% else %}/{{ year }}/scen/{% endif %}">
      Artister {{ year }}
    </a>
  </li>
  <li>
      <a href="{% if year == editions.current %}/oversikt/{% else %}/{{ year }}/oversikt/{% endif %}">
      Översikt {{ year }}
    </a>
  </li>
</ul>

{% if isArchive %}
<div class="archive-banner">
  This is an archive from {{ year }}.
  <a href="/">View current festival →</a>
</div>
<meta name="robots" content="noindex">
{% endif %}

{% if isArchive == "true" %}
  <p class="ticket-info">
    Detta är en arkiverad utgåva. Aktuella biljettpriser visas inte.
  </p>
{% else %}
  <p class="ticket-info">
    <strong>Biljettpriser {{ year }}:</strong><br>
    {% price "Vuxen", "general" %}
    {% price "Ungdom", "youth" %}
    {% price "Camping", "camping" %}
  </p>
{% endif %}

