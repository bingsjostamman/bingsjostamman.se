[
  {
    "day": "onsdag",
    "stage": "Kapellet",
    "type": "lyssna",
    "placement": "headline",
    "page": "artist",
    "name": "Merit Hemmingson",
    "ref": "merit",
    "description": "Orgelspelmannen tar sig an Bingsjömusiken på sitt eget vis och ger Pekkos Pers låtar ny form.",
    "link": "https://www.meritone.se/",
    "longdescription": "För många år sedan besökte orgelspelmannen Merit Hemmingson Bingsjöstämman. Musiken, luften och slänten upp mot Päkkosgården satte ett avtryck och sådde ett frö. Nu återvänder Merit med en fullmogen skiva, fylld med Pekkos Pers musik i elektrisk skrud. Tillsammans med trummis och slagverkare fyller hon Bingsjö kapell med välbekanta Bingsjölåtar på sitt eget sätt. Skivsläppet äger rum ett stenkast från gården där Pekkos Per levde under 1800-talet. Gården är kvar i släkten och här tog Päkkos Gustaf emot spel- och fikasugna Bingsjöstämmobesökare i över tre decennier. Pekkos Per & jag presenteras under invigningsprogrammet på Dansbanan innan kvällens konserter i kapellet.",
    "somedescription": "Orgelspelmannen Merit Hemmingson tar sig an Bingsjömusiken på sitt eget vis och ger Pekkos Pers låtar en ny, elektrisk form.",
    "eyebrow": "Konserter i kapellet",
    "image": "2026/merit-hemmingson_jws0da.jpg",
    "starttime": "19:30",
    "endtime": "20:30",
    "startMinutes": 1170,
    "endMinutes": 1230
  },
