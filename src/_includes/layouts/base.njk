<!DOCTYPE html>
<html lang="{{ site.lang }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{{ title or site.name }}</title>

    <meta name="description" content="{{ description or '' }}">
    <link rel="canonical" href="{{ canonical or site.baseUrl ~ page.url }}">

    <meta property="og:title" content="{{ title or site.title }}">
    <meta property="og:description" content="{{ description or '' }}">
    <meta property="og:image" content="{{ image or site.defaultImage }}">

    <link rel="stylesheet" href="/assets/css/styles.css">
    <link rel="stylesheet" href="/assets/css/changes.css">
    
    {% if not env.isProd %}
        <link rel="stylesheet" href="/assets/css/debug.css">
    {% endif %}

    {% if isArchive or false %}
    <meta name="robots" content="noindex, follow">
    {% endif %}
{% include "structured-data.njk" %}
</head>
<body>

<a href="#main-content" class="u-skip-link">Hoppa till innehåll</a>

{% include "components/header/header.njk" %}

    <main id="main-content" class="o-container">
        {{ content | safe }}
    </main>

{% include "components/footer/footer.njk" %}

<script type="module" src="/assets/js/main.js"></script>

</body>
</html>