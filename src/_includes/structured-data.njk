{% set org = site.organization or {} %}
{% set location = site.location or {} %}
{% set locationAddress = location.address or {} %}
{% set festivalName = site.name ~ ' ' ~ year %}
{% set pageUrl = canonical or (site.baseUrl ~ page.url) %}
{% set pageDescription = socialDescription or description or site.description %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "{{ site.baseUrl }}#organization",
  "name": "{{ org.name or site.name }}",
  "url": "{{ org.url or site.baseUrl }}"
}
</script>

{% if start and end %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Festival",
  "@id": "{{ pageUrl }}#festival",
  "name": "{{ festivalName }}",
  "url": "{{ pageUrl }}",
  "startDate": "{{ start }}",
  "endDate": "{{ end }}",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  "eventStatus": "https://schema.org/EventScheduled",
  "location": {
    "@type": "Place",
    "name": "{{ location.name or 'Bingsjo' }}",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "{{ locationAddress.streetAddress or '' }}",
      "postalCode": "{{ locationAddress.postalCode or '' }}",
      "addressLocality": "{{ locationAddress.addressLocality or '' }}",
      "addressRegion": "{{ locationAddress.addressRegion or '' }}",
      "addressCountry": "{{ locationAddress.addressCountry or 'SE' }}"
    }
  },
  "organizer": {
    "@id": "{{ site.baseUrl }}#organization"
  }
}
</script>
{% endif %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "{{ title and (title ~ ' - ' ~ site.name) or site.name }}",
  "url": "{{ pageUrl }}",
  "inLanguage": "{{ site.lang }}"{% if pageDescription %},
  "description": "{{ pageDescription }}"{% endif %}{% if start and end %},
  "about": {
    "@id": "{{ pageUrl }}#festival"
  }{% endif %}
}
</script>
