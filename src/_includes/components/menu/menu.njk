{# src/_includes/components/menu.njk #}
{% from "components/icon/icon.njk" import icon %}
<div data-menu class="c-menu">
  <!-- Starts as an <a> for no-JS fallback -->
  <a href="#main-nav" data-menu-toggle class="c-menu__toggle">
    <span class="c-menu__toggle-label">Meny</span>
    {{ icon("menu") }}
  </a>

  <!-- Backdrop only used when JS is active -->
  <div class="c-menu__backdrop" data-menu-backdrop aria-hidden="true"></div>

  {% set menuLinks = [
    { url: "/biljetter/", label: "Entré och biljetter" },
    { url: "/scen/", label: "På scen" },
    { url: "/allspel/", label: "Allspel" },
    { url: "/kurser/", label: "Kurser" },
    { url: "/kontakt/", label: "Kontakta oss" }
  ] %}

{#
    { url: "/tisdag/", label: "Tisdag", dateKey: "tisdag" },
    { url: "/onsdag/", label: "Onsdag", dateKey: "onsdag" },
    { url: "/biljetter/", label: "Entré och biljetter" }
#}

  <nav id="main-nav" data-menu-panel class="c-menu__panel t-component-header">
    <button type="button" class="c-menu__close" data-menu-close aria-label="Stäng meny">
      {{ icon("close") }}
    </button>
    <ul class="c-menu__items u-list-unstyled">
      {% for link in menuLinks %}
        <li class="c-menu__item">
          <a
            class="c-menu__link"
            href="{{ link.url }}" 
            data-track-event="menu_link_click"
            data-track-label="{{ link.label }}"
            data-track-context="main-menu"
            {% if page.url == link.url %}aria-current="page"{% endif %}
          >
            {{ link.label }}{% if link.dateKey and dates[link.dateKey] %} {{ dates[link.dateKey] | swedishDate }}{% endif %}
          </a>
        </li>
      {% endfor %}
    </ul>
  </nav>
</div>


