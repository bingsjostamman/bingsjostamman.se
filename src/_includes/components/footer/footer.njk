{% from "components/logo/logo.njk" import logo %}
{% from "components/icon/icon.njk" import icon %}

<footer class="c-footer o-container t-component-footer-top">


  <div class="c-footer__copyright">
    {{ logo("bingsjostamman", "c-footer__logo") }}
    <p>Bingsjöstämman arrangeras av Föreningen Bingsjöstämman</p>
  </div>

  
  <div class="o-container__breakout o-container t-component-footer-end">
    <div class="c-footer__partners" aria-label="Samarbetspartners och sponsorer">
      <ul class="c-footer__partner-list">
        <li class="c-footer__partner-item">{{ logo("fmh") }}<span class="u-visually-hidden">Folkmusikens Hus</span></li>
        <li class="c-footer__partner-item">{{ logo("bingsjo") }}<span class="u-visually-hidden">Bingsjö Bystugeförening</span></li>
        <li class="c-footer__partner-item">{{ logo("dsf") }}<span class="u-visually-hidden">Dalarnas Spelmansförbund</span></li>
        <li class="c-footer__partner-item">{{ logo("bilda") }}<span class="u-visually-hidden">Bilda</span></li>
        <li class="c-footer__partner-item">{{ logo("stammoveckan") }}<span class="u-visually-hidden">Stämmoveckan</span></li>
      </ul>
        {{ logo("leksands-sparbank", "c-footer__logo") }}
      <ul class="c-footer__partner-list">
      </ul>
    </div>

      <div class="c-footer__some" aria-label="Följ oss i sociala medier">
        <a class="c-footer__some-link" href="https://www.facebook.com/bingsjostamman" data-track-event="socialmedia_click" data-track-label="facebook" data-track-context="footer-social">
          <span class="u-visually-hidden">Facebook</span>{{ icon("facebook", "c-footer__some-icon") }}
        </a>
        <a class="c-footer__some-link" href="https://www.instagram.com/bingsjostamman" data-track-event="socialmedia_click" data-track-label="instagram" data-track-context="footer-social">
          <span class="u-visually-hidden">Instagram</span>{{ icon("instagram", "c-footer__some-icon") }}
        </a>
      </div>


      <div class="c-footer__copyright">
        <div><p>&copy; {{ "now" | date("yyyy") }} {{ site.name }}</p></div>
      </div>




    {% if not env.isProd %}
    <style>
    .c-footer__dev-links {
      text-align: center;
      opacity: 0.5;
    }
    .c-footer__dev-links a + a::before {
      content: " | ";
    }
    .c-footer__debug {
      text-align: center;
      opacity: 0.5;
    }
    </style>
      <p>&nbsp;</p>
      <p>&nbsp;</p>
    <p class="c-footer__debug">env.isProd = {{ env.isProd }} | env.name = {{ env.name }}</p>
    <nav class="c-footer__dev-links" aria-label="Testsidor">
      <a href="/components/">Components</a>
      <a href="/upplagor/">Editions</a>
      <a href="/test/accessibility/">Accessibility Audit</a>
      <a href="/test/pagespeed/">Page Speed Audit</a>
      <a href="/test/carbon/">Website Carbon Footprint</a>
      <a href="/404/">404</a>
      <hr />
      <a href="https://validator.w3.org/nu/?doc=https%3A%2F%2Fwww.bingsjostamman.se%2F">HTML validation</a>
      <a href="https://jigsaw.w3.org/css-validator/validator?uri=bingsjostamman.se&profile=css3svg&usermedium=all&warning=1&vextwarning=&lang=en">CSS validation</a>
      <a href="https://search.google.com/test/rich-results">Rich data result test</a>
      <a href="https://www.experte.com/page-experience">Page experience</a>
      <a href="https://yellowlab.tools/result/hj6rnsn3es">Yellow Lab Tools</a>
      <a href="https://www.ssllabs.com/ssltest/analyze.html?d=bingsjostamman.se&latest">SSL Report</a>
      <a href="https://wave.webaim.org/report#/https%3A//bingsjostamman.se">WebAim WAVE</a>
      <a href="https://securityheaders.com/?q=https%3A//bingsjostamman.se">Security Headers</a>
      <a href="https://seositecheckup.com/seo-audit/hsts-test/bingsjostamman.se">HSTS check</a>
      <p>&nbsp;</p>
    </nav>
    {% endif %}



  </div>

    <div class="c-footer__corner">
      {{ icon("fioler", "c-footer__corner-graphic") }}
    </div>

</footer>
