# Copy this file to .env.development for local use.
# Do not commit real secrets.

# PageSpeed Insights API key (optional but recommended)
PSI_API_KEY=your_pagespeed_api_key_here

# Eleventy environment
ELEVENTY_ENV=development

# Local site URL fallback used by env loader
SITE_URL=http://localhost:8080

# Optional debugging flag for CSS-related scripts
DEBUG_CSS=false
