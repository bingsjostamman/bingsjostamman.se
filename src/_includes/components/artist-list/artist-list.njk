{#-
  Component: Artist List
  Renders a list of non-headline artists with optional thumbnail,
  link to artist page, and all stage slots (grouped via ref).

  Expects in context:
    - lineup: array of act objects (full lineup)
    - year: string
    - editions: object with .current
-#}

{% from "components/image/image-card.njk" import cardImage %}
{% from "components/icon/icon.njk" import icon %}
{% from "components/artist-meta/artist-meta.njk" import artistMetaItem %}

{%- set others = [] -%}
{%- set headlineKeys = [] -%}
{%- set seenKeys = [] -%}

{%- for act in lineup -%}
  {%- if act.page == "artist" and (act.placement | trim | lower) == "headline" -%}
    {%- set headlineKey = act.ref or act.name -%}
    {%- if headlineKey and headlineKeys.indexOf(headlineKey) == -1 -%}
      {%- set headlineKeys = (headlineKeys.push(headlineKey), headlineKeys) -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- for act in lineup -%}
  {%- if act.page == "artist" -%}
    {%- set groupKey = act.ref or act.name -%}
    {%- if groupKey and headlineKeys.indexOf(groupKey) == -1 and seenKeys.indexOf(groupKey) == -1 -%}
      {%- set seenKeys = (seenKeys.push(groupKey), seenKeys) -%}
      {%- set others = (others.push(act), others) -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- if others.length -%}
<section class="c-artist-list">
  <h2 class="c-artist-list__heading">Övriga akter</h2>
  <ul class="c-artist-list__list u-list-unstyled">
    {%- for act in others | sort(false, false, 'name') %}
    <li class="c-artist-list__item {%- if act.longdescription %} t-intent-highlight{% else %} t-intent-shoutout{% endif %}">
      {%- if act.image %}
      <div class="c-artist-list__image">
        {{ cardImage(act.image | replace(".jpg", "") | replace(".png", ""), act.name) }}
      </div>
      {%- endif %}
      <div class="c-artist-list__body">
        {%- if act.longdescription %}
        <h3 class="c-artist-list__name"><a class="c-artist-list__link" href="{% if year == editions.current %}/scen/{{ act.name | slugify }}/{% else %}/{{ year }}/scen/{{ act.name | slugify }}/{% endif %}">{{ act.name }}</a></h3>
        {%- else %}
        <h3 class="c-artist-list__name">{{ act.name }}</h3>
        {%- endif %}
        {%- set slots = [] -%}
        {%- set groupKey = act.ref or act.name -%}
        {%- for slot in lineup -%}
          {%- set slotKey = slot.ref or slot.name -%}
          {%- if slot.page == "artist" and slotKey == groupKey and (slot.placement | trim | lower) != "headline" -%}
            {%- set slots = (slots.push(slot), slots) -%}
          {%- endif -%}
        {%- endfor -%}
        {%- for slot in slots %}
        {{ artistMetaItem(slot.stage, slot.day, slot.starttime, slot.endtime, {
          tag: "div",
          rootClass: "c-artist-list__meta artist-meta-item",
          infoClass: "c-artist-list__meta-info artist-meta-info",
          locationClass: "artist-meta-location"
        }) }}
        {%- endfor %}

          {% if act.longdescription %}
            <div class="c-headline-acts__cue" aria-hidden="true">
              {{ icon("arrow-forward", "c-headline-acts__cue-icon") }}
            </div>
          {% endif %}
      </div>
    </li>
    {%- endfor %}
  </ul>
</section>
{%- endif -%}
